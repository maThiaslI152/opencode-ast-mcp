# LLM Brain — OpenAI-compatible API (DeepSeek, OpenRouter, OpenAI, ollama, etc.)
# The OpenAI Python SDK is used; only BASE_URL and MODEL need to match the
# provider. The env-var names keep the historical "MINIMAX_" prefix for
# backward compatibility — they now describe any OpenAI-compatible provider.
#
# ---- DeepSeek (default) ----
# Sign up at https://platform.deepseek.com, create an API key (sk-...)
MINIMAX_API_KEY=your-deepseek-key-here
MINIMAX_BASE_URL=https://api.deepseek.com
# Model options:
#   deepseek-v4-pro   — production V4 model (full capability)
#   deepseek-v4-flash — faster, cheaper (good for patch generation)
#   (deepseek-chat and deepseek-reasoner deprecated 2026/07/24)
MINIMAX_MODEL=deepseek-v4-pro

# DeepSeek V4 reasoning mode (only used when MINIMAX_MODEL starts with "deepseek")
# reasoning_effort: "high" | "medium" | "low" — more effort = better planning, more tokens
DEEPSEEK_REASONING_EFFORT=high
# thinking: true = include reasoning trace in response (visible on stderr)
DEEPSEEK_THINKING_MODE=true

# ---- OR OpenRouter ----
# MINIMAX_API_KEY=sk-or-v1-...
# MINIMAX_BASE_URL=https://openrouter.ai/api/v1
# MINIMAX_MODEL=anthropic/claude-3.5-haiku

# ---- OR OpenAI ----
# MINIMAX_API_KEY=sk-...
# MINIMAX_BASE_URL=https://api.openai.com/v1
# MINIMAX_MODEL=gpt-4o-mini

# ---- OR local ollama ----
# MINIMAX_API_KEY=ollama
# MINIMAX_BASE_URL=http://localhost:11434/v1
# MINIMAX_MODEL=qwen2.5-coder:32b

# LM Studio (Local Worker - Qwen 18B)
LM_STUDIO_BASE=http://localhost:1234/v1
LM_STUDIO_MODEL=qwen3.5-18b-a3b-reap-coding-heretic-v0-i1

# Podman Sandbox
PODMAN_WORKSPACE=/Users/tim/Works/opencode-ast-mcp
PODMAN_IMAGE=opencode-sandbox:latest
SANDBOX_TIMEOUT=300

# Autonomous Loop Safety
MAX_AUTONOMOUS_ITERATIONS=5
THERMAL_COOLDOWN_SECONDS=3.0

# MCP Transport — "stdio" (default, local IDE), "sse", or "streamable-http"
# For LAN access: set MCP_TRANSPORT=sse, MCP_HOST=0.0.0.0, MCP_PORT=8000
MCP_TRANSPORT=stdio
MCP_HOST=127.0.0.1
MCP_PORT=8000
